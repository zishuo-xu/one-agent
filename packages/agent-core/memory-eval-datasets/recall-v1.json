{
  "version": "memory-recall-v1",
  "description": "Deterministic offline baseline for keyword recall, scope isolation, governance filters, and ranking.",
  "cases": [
    {
      "id": "english-preference-hit",
      "query": "What language do I prefer?",
      "memories": [
        { "key": "preferred language", "value": "Chinese" },
        { "key": "timezone", "value": "Shanghai" }
      ],
      "expectedSelectedKeys": ["preferred language"]
    },
    {
      "id": "chinese-unsegmented-hit",
      "query": "我最喜欢的编程语言是什么？",
      "memories": [
        { "key": "最喜欢的编程语言", "value": "Rust" },
        { "key": "常用时区", "value": "上海" }
      ],
      "expectedSelectedKeys": ["最喜欢的编程语言"]
    },
    {
      "id": "irrelevant-query-no-injection",
      "query": "讲一个关于企鹅的笑话",
      "memories": [
        { "key": "回答语言偏好", "value": "中文" },
        { "key": "项目包管理器", "value": "pnpm" }
      ],
      "expectedSelectedKeys": []
    },
    {
      "id": "thread-scope-isolation",
      "query": "What project language is used?",
      "threadId": "thread-current",
      "memories": [
        { "key": "global language", "value": "Chinese", "observedAt": "2026-01-03T00:00:00.000Z" },
        { "key": "current project language", "value": "TypeScript", "scope": "thread", "threadId": "thread-current", "observedAt": "2026-01-02T00:00:00.000Z" },
        { "key": "other project language", "value": "Rust", "scope": "thread", "threadId": "thread-other", "observedAt": "2026-01-01T00:00:00.000Z" }
      ],
      "expectedSelectedKeys": ["global language", "current project language"],
      "expectedOutcomes": { "other project language": "filtered_scope" }
    },
    {
      "id": "governance-filters",
      "query": "What is my timezone?",
      "memories": [
        { "key": "current timezone", "value": "Tokyo", "status": "active" },
        { "key": "old timezone", "value": "Shanghai", "status": "superseded" },
        { "key": "temporary timezone", "value": "London", "expiresAt": "2000-01-01T00:00:00.000Z" }
      ],
      "expectedSelectedKeys": ["current timezone"],
      "expectedOutcomes": {
        "old timezone": "filtered_inactive",
        "temporary timezone": "filtered_expired"
      }
    },
    {
      "id": "explicit-ranking-before-confidence",
      "query": "preferred editor",
      "limit": 1,
      "memories": [
        { "key": "preferred editor explicit", "value": "VS Code", "explicit": true, "confidence": 0.8 },
        { "key": "preferred editor inferred", "value": "Vim", "explicit": false, "confidence": 0.99 }
      ],
      "expectedSelectedKeys": ["preferred editor explicit"],
      "expectedOutcomes": { "preferred editor inferred": "filtered_limit" }
    }
  ]
}
