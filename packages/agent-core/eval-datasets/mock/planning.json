                "function": {
                  "name": "read_file",
                  "arguments": "{\"path\":\"data.txt\"}"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "choices": [
        {
          "message": {
            "content": "{\"complete\":true,\"reasoning\":\"Done\",\"nextAction\":\"finalize\"}"
          }
        }
      ]
