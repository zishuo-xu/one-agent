                "id": "call_1",
                "type": "function",
                "function": {
                  "name": "read_file",
                  "arguments": "{\"path\":\"wrong.txt\"}"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "choices": [
        {
          "message": {
            "content": "",
            "tool_calls": [
              {
                "id": "call_2",
                "type": "function",
                "function": {
                  "name": "read_file",
                  "arguments": "{\"path\":\"notes.txt\"}"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "choices": [
        {
          "message": {
            "content": "The reminder is to buy milk."
          }
        }
      ]
    }
  ]
