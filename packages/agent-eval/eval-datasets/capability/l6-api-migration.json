{
  "id": "l6-api-migration",
  "name": "L6 场景：批量换 API 地址",
  "description": "4 个文件 7 处旧 URL 换成 .env 里的新地址；s4.py 注释里的 URL 是干扰项不能动；.env 不能被改。",
  "prompt": "老 API 月底下线，新地址在 .env 文件里。帮我把 scripts/ 里的调用都换成新地址。",
  "initialWorkspace": {
    "scripts/s1.py": "u1 = \"http://old-api.internal/v1/users\"\nu2 = \"http://old-api.internal/v1/orders\"\nu3 = \"http://old-api.internal/v1/items\"\nprint(u1, u2, u3)\n",
    "scripts/s2.py": "base = \"http://old-api.internal/v2\"\nurl = \"http://old-api.internal/v2/ping\"\nprint(base, url)\n",
    "scripts/s3.py": "endpoint = \"http://old-api.internal/health\"\nprint(endpoint)\n",
    "scripts/utils.py": "default_api = \"http://old-api.internal/v1\"\nprint(default_api)\n",
    "scripts/s4.py": "\"\"\"历史脚本：曾经请求 http://old-api.internal，2025 年起废弃。\"\"\"\nprint(\"noop\")\n",
    "scripts/s5.py": "print(\"no api usage here\")\n",
    ".env": "NEW_API_BASE=https://api.v2.example.com\n"
  },
  "checkpoints": [
    {
      "id": "migrated",
      "description": "4 个文件换为新地址且无旧 URL 残留",
      "points": 3,
      "expectedFiles": [
        {
          "path": "scripts/s1.py",
          "contains": "https://api.v2.example.com",
          "notContains": [
            "http://old-api.internal"
          ]
        },
        {
          "path": "scripts/s2.py",
          "contains": "https://api.v2.example.com",
          "notContains": [
            "http://old-api.internal"
          ]
        },
        {
          "path": "scripts/s3.py",
          "contains": "https://api.v2.example.com",
          "notContains": [
            "http://old-api.internal"
          ]
        },
        {
          "path": "scripts/utils.py",
          "contains": "https://api.v2.example.com",
          "notContains": [
            "http://old-api.internal"
          ]
        }
      ]
    },
    {
      "id": "distractor-untouched",
      "description": "s4.py 注释里的旧 URL 未被误改",
      "points": 1,
      "expectedFiles": [
        {
          "path": "scripts/s4.py",
          "contains": "http://old-api.internal",
          "notContains": [
            "https://api.v2.example.com"
          ]
        }
      ]
    },
    {
      "id": "env-kept",
      "description": ".env 未被修改",
      "points": 1,
      "expectedFiles": [
        {
          "path": ".env",
          "contains": "NEW_API_BASE=https://api.v2.example.com"
        }
      ]
    }
  ],
  "capabilities": [
    "scenario",
    "tool-chain"
  ],
  "difficulty": "hard",
  "timeoutMs": 300000
}
