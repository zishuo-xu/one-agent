# OpenAI-compatible API configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-3.5-turbo

# Optional fallback model: requests that fail with a retryable error
# (5xx / 429 / network) automatically fail over to this endpoint.
# OPENAI_FALLBACK_BASE_URL=https://api.deepseek.com
# OPENAI_FALLBACK_API_KEY=sk-your-fallback-key
# OPENAI_FALLBACK_MODEL=deepseek-v4-flash

# Optional search provider (Brave, Tavily, Bing, etc.)
# If not set, web_search falls back to DuckDuckGo.
# Tavily example:
# SEARCH_API_URL=https://api.tavily.com/search
# SEARCH_API_KEY=YOUR_TAVILY_KEY

# Optional
PORT=3000
HOST=127.0.0.1
LOG_LEVEL=info
SYSTEM_PROMPT=You are a helpful assistant. Answer concisely and in Chinese by default.
