# Primary model protocol: openai-compatible (default) or anthropic
MODEL_PROVIDER=openai-compatible
# MODEL_TIMEOUT_MS=30000

# OpenAI-compatible primary configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-3.5-turbo

# Native Anthropic primary configuration (required only when
# MODEL_PROVIDER=anthropic)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-api-key
# If omitted, AnthropicProvider reuses OPENAI_API_KEY. This is useful for
# compatibility gateways that expose both protocols with one credential.
# ANTHROPIC_MODEL=your-claude-model
# ANTHROPIC_MAX_TOKENS=4096

# Optional protocol-neutral fallback. The primary and fallback may use
# different protocols. Retryable 5xx / 429 / network failures trigger it.
# FALLBACK_MODEL_PROVIDER=openai-compatible
# FALLBACK_BASE_URL=https://api.openai.com/v1
# FALLBACK_API_KEY=sk-your-fallback-key
# FALLBACK_MODEL=your-fallback-model
# FALLBACK_MAX_TOKENS=4096

# Legacy OpenAI fallback variables remain supported:
# OPENAI_FALLBACK_BASE_URL=https://api.deepseek.com
# OPENAI_FALLBACK_API_KEY=sk-your-fallback-key
# OPENAI_FALLBACK_MODEL=deepseek-v4-flash

# Optional per-purpose models (cost/quality tuning):
# PLANNING_MODEL is used by the planner and task judge (complex reasoning).
# UTILITY_MODEL is used for summarization and memory extraction (cheap tasks).
# PLANNING_MODEL=deepseek-reasoner
# UTILITY_MODEL=deepseek-v4-flash

# Optional search provider (Brave, Tavily, Bing, etc.)
# If not set, web_search falls back to DuckDuckGo.
# Tavily example:
# SEARCH_API_URL=https://api.tavily.com/search
# SEARCH_API_KEY=YOUR_TAVILY_KEY

# Optional
PORT=3000
HOST=127.0.0.1
LOG_LEVEL=info
SYSTEM_PROMPT=You are a helpful assistant. Answer concisely and in Chinese by default.

# Comma-separated tool names to disable (e.g. when exposing the API publicly,
# shell access should be turned off):
# DISABLED_TOOLS=run_command,delete_file
