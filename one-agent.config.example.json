{
  "version": 1,
  "model": {
    "provider": "openai-compatible",
    "baseUrl": "https://api.openai.com/v1",
    "apiKey": "your-api-key",
    "model": "gpt-3.5-turbo",
    "maxTokens": 4096,
    "timeoutMs": 30000
  },
  "runtime": {
    "systemPrompt": "You are a helpful assistant. Answer concisely and in Chinese by default. When you use the web_search tool, base your answer strictly on the search results returned. If the search returns no useful results, tell the user clearly instead of making up information.",
    "loop": "auto",
    "maxRetries": 2,
    "maxToolIterations": 5,
    "maxReplanAttempts": 3,
    "maxRetryAttempts": 2
  },
  "context": {
    "maxTokens": 4096,
    "recentTokenBudget": 2048
  },
  "strategy": {
    "maxInitialToolBatch": 2,
    "maxSwitches": 1
  },
  "subAgent": {
    "enabled": true,
    "maxDepth": 1,
    "maxTasksPerRun": 8,
    "maxConcurrency": 4,
    "maxTotalTokens": 50000,
    "taskTimeoutMs": 60000,
    "maxToolIterations": 5
  },
  "tools": {
    "disabled": [],
    "search": {}
  },
  "trace": {
    "contentMode": "redacted",
    "host": "127.0.0.1",
    "port": 3001,
    "logLevel": "info"
  },
  "storage": {
    "databasePath": "data.db"
  },
  "api": {
    "host": "127.0.0.1",
    "port": 3000,
    "logLevel": "info"
  },
  "taskQueue": {
    "maxConcurrency": 2,
    "taskTimeoutMs": 300000,
    "maxRetries": 3,
    "retryDelayMs": 1000
  },
  "cli": {
    "color": true
  }
}
